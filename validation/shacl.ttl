@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

########################################
# 📚 BOOK CONSTRAINTS
########################################
ex:BookShape
    a sh:NodeShape ;
    sh:targetClass ex:Book ;

    sh:property [
        sh:path ex:writtenBy ;
        sh:minCount 1 ;
        sh:message "A book must have at least one author." ;
    ] ;
    sh:property [
        sh:path ex:belongsToCategory ;
        sh:minCount 1 ;
        sh:message "A book must belong to at least one category." ;
    ] ;
    sh:property [
        sh:path ex:bookPrice ;
        sh:minCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message "A book must have a price." ;
    ] .
########################################
# 👤 CUSTOMER CONSTRAINTS
########################################
ex:CustomerShape
    a sh:NodeShape ;
    sh:targetClass ex:Customer ;
    sh:property [
        sh:path ex:hasOrder ;
        sh:minCount 0 ;
        sh:message "Customer may have orders." ;
    ] .
########################################
# ⭐ REVIEW CONSTRAINTS
########################################
ex:ReviewShape
    a sh:NodeShape ;
    sh:targetClass ex:Review ;
    sh:property [
        sh:path ex:rating ;
        sh:minCount 1 ;
        sh:minInclusive 1 ;
        sh:maxInclusive 5 ;
        sh:datatype xsd:integer ;
        sh:message "Rating must be between 1 and 5." ;
    ] ;
    sh:property [
        sh:path ex:reviewOf ;
        sh:minCount 1 ;
        sh:message "Review must be linked to a book." ;
    ] .