#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Author
:Author rdf:type owl:Class ;
        rdfs:subClassOf :Person .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Book
:Book rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :belongsToCategory ;
                        owl:someValuesFrom :Category
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :publishedBy ;
                        owl:someValuesFrom :Publisher
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :writtenBy ;
                        owl:someValuesFrom :Author
                      ] .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Cart
:Cart rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Category
:Category rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Customer
:Customer rdf:type owl:Class ;
          rdfs:subClassOf :Person ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :addedToCart ;
                            owl:someValuesFrom :Book
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasOrder ;
                            owl:someValuesFrom :Order
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasWishlist ;
                            owl:someValuesFrom :Wishlist
                          ] .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Favorite
:Favorite rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Feedback
:Feedback rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Order
:Order rdf:type owl:Class ;
       owl:equivalentClass [ rdf:type owl:Restriction ;
                             owl:onProperty :hasPayment ;
                             owl:someValuesFrom :Payment
                           ] ;
       rdfs:subClassOf :Transaction .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Payment
:Payment rdf:type owl:Class ;
         rdfs:subClassOf :Transaction .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Person
:Person rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Publisher
:Publisher rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Recommendation
:Recommendation rdf:type owl:Class ;
                rdfs:subClassOf :Feedback ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :recommendedTo ;
                                  owl:someValuesFrom :Customer
                                ] .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Review
:Review rdf:type owl:Class ;
        rdfs:subClassOf :Feedback ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :reviewOf ;
                          owl:someValuesFrom :Book
                        ] .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Transaction
:Transaction rdf:type owl:Class .


###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#Wishlist
:Wishlist rdf:type owl:Class .


