###  http://www.semanticweb.org/lenovo/ontologies/2026/3/untitled-ontology-21#addedToCart
:addedToCart rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain [ rdf:type owl:Restriction ;
                           owl:onProperty :addedToCart ;
                           owl:someValuesFrom :Book
                         ] .


